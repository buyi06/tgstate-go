# Telegram Bot Token (必需)
BOT_TOKEN=

# Telegram Channel ID (必需)
# 格式: -1001234567890 或 @channel_username
CHANNEL_NAME=

# 公开访问的域名 (可选)
# 例如: https://pan.yourdomain.com
BASE_URL=

# 服务端口 (默认 8000)
PORT=8000

# 管理员密码 (首次启动后设置)
PASSWORD=

# 数据库路径 (可选)
DATABASE_PATH=./data/file_metadata.db

# 日志级别 (可选: DEBUG, INFO, WARN, ERROR)
LOG_LEVEL=INFO
